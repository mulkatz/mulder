{
	"name": "mulder",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@10.29.3",
	"engines": {
		"node": ">=20.0.0"
	},
	"scripts": {
		"build": "turbo run build",
		"typecheck": "turbo run typecheck",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx}": "biome check --write",
		"*.json": "biome format --write"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@types/pg": "^8.20.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"pg": "^8.20.0",
		"turbo": "^2.3.0",
		"typescript": "^5.7.0",
		"vitest": "^3.0.0"
	}
}
